# ============================================================
# VideoCreatorAI — Environment Variables Template
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to version control.
# ============================================================

# NVIDIA NIM API Key
# Get yours at: https://integrate.api.nvidia.com/
NVIDIA_API_KEY=your_nvidia_nim_api_key_here

# ElevenLabs API Key
# Get yours at: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs Voice ID (optional — leave blank to be prompted)
# Browse voices at: https://elevenlabs.io/voice-library
# Recommended American narrators: Adam, Josh, Daniel
ELEVENLABS_VOICE_ID=

# OpenAI API Key (for Whisper transcription)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Pexels API Key (for stock footage)
# Get yours at: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Pixabay API Key (fallback for stock footage)
# Get yours at: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_api_key_here

# Output directory (optional — defaults to ./output)
OUTPUT_DIR=./output

# Media directory (optional — defaults to ./media)
MEDIA_DIR=./media
